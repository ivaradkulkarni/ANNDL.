    {
      "cell_type": "code",
      "source": [
        "prices = df['Close'].values.flatten()\n",
        "\n",
        "actions = [0, 1, 2]  # Hold, Buy, Sell\n",
        "\n",
        "q_table = np.zeros((len(prices), len(actions)))\n",
        "\n",
        "alpha = 0.1\n",
        "gamma = 0.9\n",
        "epsilon = 0.1"
      ],
      "metadata": {
        "id": "YXqvLwiqBFIk"
      },
      "execution_count": 84,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "### Training the RL Agent\n",
        "\n",
        "The agent learns by interacting with stock prices and updating the Q-table based on rewards."
      ],
      "metadata": {
        "id": "wucsyFSYBMaN"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "for episode in range(10):\n",
        "    total_reward = 0\n",
        "\n",
        "    for t in range(len(prices)-1):\n",
        "\n",
        "        if np.random.rand() < epsilon:\n",
        "            action = np.random.choice(actions)\n",
        "        else:\n",
        "            action = np.argmax(q_table[t])\n",
        "\n",
        "        price_today = prices[t]\n",
        "        price_next = prices[t+1]\n",
        "\n",
        "        if action == 1:\n",
        "            reward = price_next - price_today\n",
        "        elif action == 2:\n",
        "            reward = price_today - price_next\n",
        "        else:\n",
        "            reward = 0\n",
        "\n",
        "        q_table[t, action] += alpha * (\n",
        "            reward + gamma * np.max(q_table[t+1]) - q_table[t, action]\n",
        "        )\n",
        "\n",
        "        total_reward += reward\n",
        "\n",
        "    print(f\"Episode {episode+1}, Reward: {total_reward}\")"
      ],
